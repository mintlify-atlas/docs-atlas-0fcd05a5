  "keyFeatures": [
    "Import public procurement data from Excel files",
    "Store data natively in OCDS format using MongoDB",
    "Live analytics dashboard with interactive charts and maps",
    "Filter and compare procurement data across multiple dimensions",
    "Export data in OCDS-compliant format",
    "Corruption risk indicators and red flag detection",
    "Multi-module Spring Boot architecture",
    "Apache Wicket admin interface for data management"
  ],
